# Server Configuration
PORT=3001
NODE_ENV=development

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your.api.identifier

# Seed Configuration (optional)
# If credentials are set, seed imports users from Auth0 Management API.
# If credentials are not set, seed uses existing DB users only.
# AUTH0_MANAGEMENT_API_TOKEN=
# AUTH0_M2M_CLIENT_ID=
# AUTH0_M2M_CLIENT_SECRET=
# AUTH0_MANAGEMENT_API_AUDIENCE=https://your-tenant.auth0.com/api/v2/

# CORS Configuration (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database Connection String
DATABASE_URL=
