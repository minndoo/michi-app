# Server Configuration
PORT=3001
NODE_ENV=development

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your.api.identifier

# Seed Configuration (optional)
# If credentials are set, seed imports users from Auth0 Management API.
# If credentials are not set, seed uses existing DB users only.
# AUTH0_MANAGEMENT_API_TOKEN=
# AUTH0_M2M_CLIENT_ID=
# AUTH0_M2M_CLIENT_SECRET=
# AUTH0_MANAGEMENT_API_AUDIENCE=https://your-tenant.auth0.com/api/v2/

# CORS Configuration (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database Connection String
DATABASE_URL=

# Router LLM Configuration
ROUTER_LLM_PROVIDER=ollama
ROUTER_LLM_MODEL=llama3.2:3b
ROUTER_LLM_BASE_URL=http://127.0.0.1:11434
ROUTER_LLM_TEMPERATURE=0

# Planner LLM Configuration
PLANNER_LLM_PROVIDER=ollama
PLANNER_LLM_MODEL=llama3.2:3b
PLANNER_LLM_BASE_URL=http://127.0.0.1:11434
PLANNER_LLM_TEMPERATURE=0

# Redis Short-Term Memory
REDIS_URL=redis://127.0.0.1:6379
REDIS_SHORT_TERM_TTL_SECONDS=86400

# LangGraph Postgres Long-Term Memory
LANGGRAPH_MEMORY_NAMESPACE=agent
