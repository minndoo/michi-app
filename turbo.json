{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "API_BASE_URL",
        "AUTH0_AUDIENCE",
        "DATABASE_URL",
        "PORT",
        "AUTH0_DOMAIN",
        "ALLOWED_ORIGINS",
        "ORVAL_INPUT",
        "REDIS_URL",
        "REASONING_LLM_PROVIDER",
        "REASONING_LLM_MODEL",
        "REASONING_LLM_BASE_URL",
        "REASONING_LLM_TEMPERATURE",
        "FAST_LLM_PROVIDER",
        "FAST_LLM_MODEL",
        "FAST_LLM_BASE_URL",
        "FAST_LLM_TEMPERATURE"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
